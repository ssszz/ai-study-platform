{
  "name": "AI Study Platform",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": { "label": "AI研习社", "onAutoForward": "openPreview" }
  },
  "postCreateCommand": "cd frontend && npm install && npm run build && cd .. && pip install -r backend/requirements.txt && cd backend && rm -f ai_study.db && python -m app.seed && cd ..",
  "postStartCommand": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8000",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "dbaeumer.vscode-eslint"]
    }
  }
}
